# PBXMonitorX Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to version control.

# ── Database ──────────────────────────────────────
DB_PASSWORD=changeme_strong_password_here

# ── Redis ─────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password_here

# ── Encryption ────────────────────────────────────
# 32-byte hex key for AES-256-GCM. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
MASTER_ENCRYPTION_KEY=

# ── JWT ───────────────────────────────────────────
# Secret for signing JWT tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# ── Domain ───────────────────────────────────────
# Used by nginx for server_name and SSL certificate paths
DOMAIN=example.com

# ── App Settings ──────────────────────────────────
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# ── Azure AD SSO (Optional) ──────────────────────
# Set AZURE_AD_ENABLED=true and fill in tenant details to enable SSO
AZURE_AD_ENABLED=false
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=https://yourdomain.com/api/auth/sso/callback
AZURE_AD_AUTO_CREATE_USERS=true
AZURE_AD_DEFAULT_ROLE=viewer

# ── Backup Storage ────────────────────────────────
# Inside container: /data/backups (mapped via Docker volume)
# Encryption-at-rest for backups (true/false)
ENCRYPT_BACKUPS=false
